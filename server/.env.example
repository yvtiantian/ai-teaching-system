# AI Teaching System - Server Environment Configuration
# Copy this file to .env and fill in your values

# --- Server ---
DEBUG=true

# --- DeepSeek (Cloud LLM) ---
DEEPSEEK__API_KEY=your-deepseek-api-key-here
DEEPSEEK__DEFAULT_MODEL=deepseek-chat
# Optional: override chat/title model independently
# DEEPSEEK__CHAT_MODEL=deepseek-chat
# DEEPSEEK__TITLE_MODEL=deepseek-chat

# --- Supabase Cloud ---
SUPABASE__URL=https://bynryweltcwamzonwaiy.supabase.co
SUPABASE__ANON_KEY=your-anon-key-here
SUPABASE__SERVICE_KEY=your-service-key-here
SUPABASE__JWT_SECRET=your-jwt-secret-here
